---
import SecondaryCTA from '@components/ui/buttons/SecondaryCTA.astro';
import Icon from '@components/ui/icons/Icon.astro';

const { pricing } = Astro.props;

type Product = {
  name: string;
  description: string;
  price: string;
  cents: string;
  billingFrequency: string;
  features: Array<string>;
  purchaseBtnTitle: string;
  purchaseLink: string;
};

const packs: Array<Product> = [
  pricing.pack1,
  pricing.pack2,
  pricing.pack3,
  pricing.pack4,
];
---

<section
  class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full"
  id="pricing-carousel"
>
  <div class="mx-auto mb-10 max-w-2xl text-center lg:mb-14">
    <h2
      class="text-2xl font-bold tracking-tight text-balance text-neutral-800 md:text-4xl md:leading-tight dark:text-neutral-200"
    >
      {pricing.title}
    </h2>
    <p class="mt-1 text-pretty text-neutral-600 dark:text-neutral-400">
      {pricing.subTitle}
    </p>
  </div>

  <div class="relative mx-auto max-w-4xl">
    <div id="pricing-track" class="overflow-hidden">
      <div class="flex transition-transform duration-500" id="pricing-inner">
        {[0, 2].map((startIdx) => (
          <div class="flex w-full shrink-0 flex-wrap items-center justify-center gap-4 sm:gap-0" data-slide={startIdx / 2}>
            <div class="w-full rounded-xl bg-gray-800 p-6 sm:w-1/2 sm:rounded-r-none sm:p-8 lg:w-1/3">
              <div class="mb-4">
                <h3 class="text-2xl font-bold text-neutral-100 sm:text-3xl">{packs[startIdx].name}</h3>
                <p class="text-indigo-300">{packs[startIdx].description}</p>
              </div>
              <div class="mb-4">
                <span class="text-4xl font-bold text-neutral-200">{packs[startIdx].price}</span>
                <span class="ms-3 text-sm text-indigo-200">{packs[startIdx].billingFrequency}</span>
              </div>
              <ul class="mb-6 space-y-2 text-neutral-300">
                {packs[startIdx].features.map((feature: string) => (
                  <li class="flex items-center gap-1.5">
                    <Icon name="checkCircle" />
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
              <a href={packs[startIdx].purchaseLink} class="block rounded-lg bg-gray-500 px-8 py-3 text-center text-sm font-bold text-gray-100 ring-indigo-300 outline-hidden transition duration-100 hover:bg-gray-600 focus-visible:ring-3 active:text-gray-300 md:text-base">{packs[startIdx].purchaseBtnTitle}</a>
            </div>
            <div class="w-full rounded-xl bg-linear-to-tr from-[#FF512F] to-[#F09819] p-6 shadow-xl sm:w-1/2 sm:p-8">
              <div class="mb-4 flex flex-col items-start justify-between gap-4 lg:flex-row">
                <div>
                  <h3 class="text-2xl font-bold text-neutral-100 sm:text-3xl">{packs[startIdx + 1].name}</h3>
                  <p class="text-orange-200">{packs[startIdx + 1].description}</p>
                </div>
                <span class="bg-opacity-50 order-first inline-block rounded-full bg-orange-200/60 px-3 py-1 text-center text-xs font-bold tracking-wider text-orange-600 uppercase lg:order-none">{pricing.badge}</span>
              </div>
              <div class="mb-4">
                <span class="text-6xl font-bold text-neutral-100">{packs[startIdx + 1].price}</span>
                <span class="ms-3 text-orange-200">{packs[startIdx + 1].billingFrequency}</span>
              </div>
              <ul class="mb-6 space-y-2 text-orange-100">
                {packs[startIdx + 1].features.map((feature: string) => (
                  <li class="flex items-center gap-1.5">
                    <Icon name="checkCircle" />
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
              <a href={packs[startIdx + 1].purchaseLink} class="bg-opacity-50 block rounded-lg bg-orange-200/40 px-8 py-3 text-center text-sm font-bold text-neutral-100 ring-orange-300 outline-hidden transition duration-300 hover:bg-orange-300 focus-visible:ring-3 active:bg-orange-400 md:text-base">{packs[startIdx + 1].purchaseBtnTitle}</a>
            </div>
          </div>
        ))}
      </div>
    </div>

    <button
      id="prev-slide"
      class="absolute top-1/2 -left-4 z-10 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-white shadow-lg transition hover:bg-neutral-100 dark:bg-neutral-700 dark:hover:bg-neutral-600"
      aria-label="Previous"
    >
      <svg class="h-5 w-5 text-neutral-700 dark:text-neutral-200" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </button>
    <button
      id="next-slide"
      class="absolute top-1/2 -right-4 z-10 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-white shadow-lg transition hover:bg-neutral-100 dark:bg-neutral-700 dark:hover:bg-neutral-600"
      aria-label="Next"
    >
      <svg class="h-5 w-5 text-neutral-700 dark:text-neutral-200" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </button>

    <div class="mt-6 flex justify-center gap-2">
      {Array.from({ length: Math.ceil(packs.length / 2) }).map((_, i) => (
        <button
          class="h-2.5 w-2.5 rounded-full bg-neutral-300 transition hover:bg-neutral-500 data-[active=true]:bg-orange-400 dark:bg-neutral-600 dark:data-[active=true]:bg-orange-400"
          data-dot={i}
          aria-label={`Slide ${i + 1}`}
        ></button>
      ))}
    </div>
  </div>

  <div class="mt-8 flex items-center justify-center gap-x-3 md:mt-12">
    <p class="text-sm text-neutral-600 dark:text-neutral-400">
      {pricing.thirdOption}
    </p>
    <SecondaryCTA title={pricing.btnText} url="#" />
  </div>
</section>

<script>
  const inner = document.getElementById('pricing-inner');
  const prevBtn = document.getElementById('prev-slide');
  const nextBtn = document.getElementById('next-slide');
  const dots = document.querySelectorAll('[data-dot]');
  let current = 0;
  const total = dots.length;

  function showSlide(index: number) {
    if (!inner) return;
    inner.style.transform = `translateX(-${index * 100}%)`;
    dots.forEach((dot, i) => {
      dot.setAttribute('data-active', i === index ? 'true' : 'false');
    });
    current = index;
  }

  if (prevBtn && nextBtn) {
    prevBtn.addEventListener('click', () => {
      showSlide(current > 0 ? current - 1 : total - 1);
    });
    nextBtn.addEventListener('click', () => {
      showSlide(current < total - 1 ? current + 1 : 0);
    });
  }

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      showSlide(parseInt(dot.getAttribute('data-dot') || '0'));
    });
  });

  showSlide(0);
</script>
