---
// Import necessary components
import MainLayout from '@/layouts/MainLayout.astro';
import MainSection from '@components/ui/blocks/MainSection.astro';
import LeftSection from '@components/ui/blocks/LeftSection.astro';
import RightSection from '@components/ui/blocks/RightSection.astro';
import FeaturesStats from '@components/sections/features/FeaturesStats.astro';

// Import necessary images
import blueprints from '@images/blueprints-image.avif';
import personWorking from '@images/person-working.avif';
import beforeAfter from '@images/before-after.avif';
import constructionWorkers from '@images/construction-workers.avif';
import aerialView from '@images/aerial-view.avif';
import usingTools from '@images/using-tools.avif';
import progressBuilding from '@images/progress-building.avif';
import underConstruction from '@images/under-construction.avif';
import { SITE } from '@data/constants';

interface Article {
  isRightSection: boolean;
  title: string;
  subTitle: string;
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
  single?: boolean;
  img?: any;
  imgAlt?: string;
  imgOne?: any;
  imgOneAlt?: string;
  imgTwo?: any;
  imgTwoAlt?: string;
}

const articles: Article[] = [
  {
    isRightSection: true,
    title: 'Consulting 360°',
    subTitle:
      'Diagnostic organisationnel, analyse des processus et plans d\'amélioration pour optimiser la performance de votre entreprise. Nous accompagnons la création, la structuration et le développement des activités avec une approche sur mesure.',
    single: false,
    imgOne: blueprints,
    imgOneAlt: 'Consulting stratégique',
    imgTwo: personWorking,
    imgTwoAlt: 'Accompagnement entrepreneur',
  },
  {
    isRightSection: false,
    title: 'Services Opérationnels',
    subTitle:
      'Gestion des achats et sourcing international, accompagnement à l\'importation et gestion des réseaux sociaux. Des solutions concrètes pour améliorer votre approvisionnement, votre communication et votre efficacité opérationnelle.',
    img: beforeAfter,
    imgAlt: 'Services opérationnels',
    btnExists: true,
    btnTitle: 'En savoir plus',
    btnURL: '#',
  },
  {
    isRightSection: true,
    title: 'Capital Humain & Performance',
    subTitle:
      'Orientation académique et professionnelle, coaching et leadership, team building et formations professionnelles. Parce que la réussite d\'une organisation repose avant tout sur les femmes et les hommes qui la composent.',
    single: false,
    imgOne: constructionWorkers,
    imgOneAlt: 'Développement des talents',
    imgTwo: aerialView,
    imgTwoAlt: 'Performance collective',
  },
  {
    isRightSection: false,
    title: 'Formations Professionnelles',
    subTitle:
      'Entrepreneuriat, gestion de projet, marketing et vente, communication professionnelle, leadership et management. Des formations pratiques adaptées aux besoins des particuliers, des entrepreneurs et des entreprises.',
    img: usingTools,
    imgAlt: 'Formation professionnelle',
  },
  {
    isRightSection: true,
    title: 'Accompagnement Entrepreneurial',
    subTitle:
      'Coaching entrepreneurial, développement commercial, structuration des activités et suivi des performances. Nous vous guidons dans la mise en œuvre des actions pour atteindre vos objectifs de croissance.',
    single: false,
    imgOne: progressBuilding,
    imgOneAlt: 'Croissance entrepreneuriale',
    imgTwo: underConstruction,
    imgTwoAlt: 'Accompagnement stratégique',
    btnExists: true,
    btnTitle: 'Contactez-nous',
    btnURL: '#',
  },
];

const pageTitle: string = `Services | ${SITE.title}`;
const metaDescription =
  'PARAH Consulting & Services propose 3 pôles d\'expertise : Consulting 360°, Services Opérationnels, et Capital Humain & Performance. Conseil, formation et accompagnement à Brazzaville.';
const ogTitle = 'Nos Services | PARAH Consulting & Services';
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://www.parah-consulting.com/services',
    url: 'https://www.parah-consulting.com/services',
    name: 'Nos Services | PARAH Consulting & Services',
    description:
      'PARAH Consulting & Services propose 3 pôles d\'expertise : Consulting 360°, Services Opérationnels, et Capital Humain & Performance.',
    isPartOf: {
      '@type': 'WebSite',
      url: 'https://www.parah-consulting.com',
      name: 'PARAH',
      description:
        'PARAH Consulting & Services — Votre levier de croissance à Brazzaville.',
    },
    inLanguage: 'en-US',
  }}
>
  {
    /* MainSection is the introductory section of the page, it also contains a CTA button */
  }
  <MainSection
    title="3 pôles d'expertise pour votre réussite"
    subTitle="PARAH intervient aux côtés des entrepreneurs, des PME et des institutions pour transformer le potentiel en performance. Découvrez nos trois pôles d'expertise complémentaires."
    btnExists={true}
    btnTitle="Contactez-nous"
    btnURL="/contact"
  />
  {
    /* RightSection and LeftSection contain details about various services along with pertinent imagery.
  They alternate for variety in design.
  The 'btnExists' property is used to toggle the display of a button in these sections.
  When btnExists={true}, a button is displayed.
  This can be used to link to more detailed information or related resources.
  RightSection can also conditionally render one or two images based on the 'single' property.
  If 'single' is true, it displays one image, otherwise it displays two.
  */
  }
  {
    articles.map(article => {
      return article.isRightSection ? (
        <RightSection
          title={article.title}
          subTitle={article.subTitle}
          single={article.single}
          imgOne={article.imgOne}
          imgOneAlt={article.imgOneAlt}
          imgTwo={article.imgTwo}
          imgTwoAlt={article.imgTwoAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      ) : (
        <LeftSection
          title={article.title}
          subTitle={article.subTitle}
          img={article.img}
          imgAlt={article.imgAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      );
    })
  }
  {/* FeaturesStats section showcases essential stats valuable to users */}
  <FeaturesStats
    title="Nos chiffres clés"
    subTitle="Notre engagement pour la qualité et la satisfaction de nos clients est mesurable. Chaque mission est une opportunité de faire la différence."
    mainStatTitle="98%"
    mainStatSubTitle="de nos clients recommandent PARAH"
    stats={[
      {
        stat: '3',
        description: 'pôles d\'expertise complémentaires',
      },
      {
        stat: '50+',
        description: 'missions réalisées avec succès',
      },
      {
        stat: '100%',
        description: 'engagement pour votre réussite',
      },
    ]}
  />
</MainLayout>
