<svg viewBox="0 0 1440 900" fill="none" {...Astro.props}>
  <defs>
    <linearGradient id="waveFade" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#1B2A6B" stop-opacity="0.22" />
      <stop offset="35%" stop-color="#1B2A6B" stop-opacity="0.12" />
      <stop offset="65%" stop-color="#1B2A6B" stop-opacity="0.04" />
      <stop offset="100%" stop-color="#1B2A6B" stop-opacity="0" />
    </linearGradient>
    <linearGradient id="waveFade2" x1="1" y1="1" x2="0" y2="0">
      <stop offset="0%" stop-color="#1B2A6B" stop-opacity="0.22" />
      <stop offset="35%" stop-color="#1B2A6B" stop-opacity="0.12" />
      <stop offset="65%" stop-color="#1B2A6B" stop-opacity="0.04" />
      <stop offset="100%" stop-color="#1B2A6B" stop-opacity="0" />
    </linearGradient>
  </defs>

  <!-- Top-left wave mass — déployé -->
  <g stroke="url(#waveFade)" stroke-width="1.5" fill="none">
    {Array.from({ length: 55 }).map((_, i) => {
      const s = i * 6;
      const x0 = -60 + s * 0.5;
      const y0 = -40 + s * 0.2;
      const c1x = 180 + s * 0.45;
      const c1y = 100 + s * 0.3;
      const c2x = 400 + s * 0.5;
      const c2y = 280 + s * 0.15;
      const x3 = 600 + s * 0.25;
      const y3 = 230 + s * 0.05;
      const c3x = 750 + s * 0.15;
      const c3y = 180 + s * 0.1;
      const c4x = 850 + s * 0.1;
      const c4y = 320 + s * 0.08;
      const x5 = 950 + s * 0.05;
      const y5 = 300 + s * 0.03;
      return <path d={`M${x0} ${y0} C${c1x} ${c1y}, ${c2x} ${c2y}, ${x3} ${y3} C${c3x} ${c3y}, ${c4x} ${c4y}, ${x5} ${y5}`} />;
    })}
  </g>

  <!-- Bottom-right wave mass — déployé -->
  <g stroke="url(#waveFade2)" stroke-width="1.5" fill="none">
    {Array.from({ length: 55 }).map((_, i) => {
      const s = i * 6;
      const x0 = 1440 + 60 - s * 0.5;
      const y0 = 900 + 40 - s * 0.2;
      const c1x = 1260 - s * 0.45;
      const c1y = 800 - s * 0.3;
      const c2x = 1040 - s * 0.5;
      const c2y = 620 - s * 0.15;
      const x3 = 840 - s * 0.25;
      const y3 = 670 - s * 0.05;
      const c3x = 690 - s * 0.15;
      const c3y = 720 - s * 0.1;
      const c4x = 590 - s * 0.1;
      const c4y = 580 - s * 0.08;
      const x5 = 490 - s * 0.05;
      const y5 = 600 - s * 0.03;
      return <path d={`M${x0} ${y0} C${c1x} ${c1y}, ${c2x} ${c2y}, ${x3} ${y3} C${c3x} ${c3y}, ${c4x} ${c4y}, ${x5} ${y5}`} />;
    })}
  </g>

  <!-- Center crossing S-curve — déployé -->
  <g stroke="#1B2A6B" stroke-width="1" fill="none" opacity="0.07">
    <path d="M450 200 C550 300, 600 480, 720 520 C840 560, 900 420, 1020 480 C1140 540, 1180 680, 1220 720" />
    <path d="M465 215 C565 315, 615 495, 735 535 C855 575, 915 435, 1035 495 C1155 555, 1195 695, 1235 735" />
    <path d="M480 230 C580 330, 630 510, 750 550 C870 590, 930 450, 1050 510 C1170 570, 1210 710, 1250 750" />
    <path d="M495 245 C595 345, 645 525, 765 565 C885 605, 945 465, 1065 525 C1185 585, 1225 725, 1265 765" />
    <path d="M510 260 C610 360, 660 540, 780 580 C900 620, 960 480, 1080 540 C1200 600, 1240 740, 1280 780" />
    <path d="M525 275 C625 375, 675 555, 795 595 C915 635, 975 495, 1095 555 C1215 615, 1255 755, 1295 795" />
    <path d="M540 290 C640 390, 690 570, 810 610 C930 650, 990 510, 1110 570 C1230 630, 1270 770, 1310 810" />
  </g>
</svg>
